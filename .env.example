# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Public Asset URL for images and music (e.g. Supabase Storage Public URL)
NEXT_PUBLIC_ASSET_URL=https://jmiclzggamlyxjmerqed.supabase.co/storage/v1/object/public/map-assets

# Data source: 'local' for JSON files, 'database' for Supabase
DATA_SOURCE=local

# Sentry Configuration (Optional - for error tracking in production)
# Get your DSN from https://sentry.io by creating a Next.js project
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Sentry Auth Token (Required for Vercel deployment to upload source maps)
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
